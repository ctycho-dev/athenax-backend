COOKIE_SECURE=true
COOKIE_SAMESITE=none

CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:3000
CORS_ORIGIN_REGEX=https://athenax-research-.*\.vercel\.app

# Postgres
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=athenax_db
DATABASE_URL=postgresql+asyncpg://root:password@localhost:5432/athenax_db
DATABASE_DIRECT_URL=postgresql://root:password@localhost:5432/athenax_db

# Redis
REDIS_PASSWORD=password
REDIS_URL=redis://:password@localhost:6379

# OAuth2
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Internal service-to-service auth (X-Internal-Key header)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable all internal endpoints.
INTERNAL_API_KEY=

# Resend
RESEND_API_KEY=your_resend_api_key_here

# Frontend — used to build email links (verify-email, reset-password)
FRONTEND_URL=http://localhost:3000

# Cloudflare R2
R2_ACCESS_KEY=YOUR_ACCESS_KEY
R2_SECRET_KEY=YOUR_SECRET_KEY
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=your_bucket_name
R2_CDN_BASE_URL=https://your-cdn-url.com

# Logo.dev — auto-fetch company logos by domain (https://logo.dev)
LOGO_DEV_PUBLISHABLE_KEY=your_logo_dev_publishable_key
