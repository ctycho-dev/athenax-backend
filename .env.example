COOKIE_SECURE=true
COOKIE_SAMESITE=none

CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:3000

# Postgres
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=athenax_db
DATABASE_URL=postgresql+asyncpg://root:password@localhost:5432/athenax_db

# Redis
REDIS_PASSWORD=password
REDIS_URL=redis://:password@localhost:6379

# OAuth2
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Resend
RESEND_API_KEY=your_resend_api_key_here

# Frontend — used to build email links (verify-email, reset-password)
FRONTEND_URL=http://localhost:3000
